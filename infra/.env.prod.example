# Production deploy-time variables. Copy to .env on the host (same file the
# base compose already reads via env_file) and fill in real values.
# Nothing here names a specific provider: any Ubuntu host with Docker works.

# --- Edge / TLS ---
# Public domain Caddy serves and provisions TLS for (e.g. a DuckDNS subdomain).
ARGUS_DOMAIN=argus.example.duckdns.org
# Contact email for Let's Encrypt.
ARGUS_ACME_EMAIL=you@example.com
# Optional: override the frontend upstream. Empty = the compose frontend
# container. Point at a Vercel URL only if you want Caddy to proxy it (normally
# you don't; Vercel serves the frontend directly).
ARGUS_FRONTEND_TARGET=

# --- Images ---
# GHCR namespace and tag pulled by docker-compose.prod.yml.
GHCR_OWNER=carolina-kp
IMAGE_TAG=latest

# --- Application (same variables the base compose/.env already uses) ---
POSTGRES_USER=argus
POSTGRES_PASSWORD=change-me
POSTGRES_DB=argus
API_TOKEN=change-me
GEMINI_API_KEY=
GROQ_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
BRIEF_EMAIL_TO=

# --- Backups (infra/backup/backup.sh) ---
# Offsite target: "github-release" (default, zero-cost) or "s3" (any
# S3-compatible endpoint, e.g. Oracle Object Storage later).
BACKUP_TARGET=github-release
# Fine-grained PAT with contents:write on the repo, for github-release target.
BACKUP_GITHUB_TOKEN=
BACKUP_GITHUB_REPO=carolina-kp/argus-backups
# Local retention (days) on the host before pruning.
BACKUP_RETENTION_DAYS=7
# s3 target only:
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
