# Argus frontend environment.
# Copy to .env.local for local development (never commit .env.local).

# Base URL of the FastAPI backend (server-side only, no NEXT_PUBLIC_ prefix
# so the token and internal URL are never shipped to the browser).
ARGUS_API_URL=http://localhost:8000

# Single-user bearer token expected by the API (must match the backend's
# API_TOKEN). Server-side only.
ARGUS_API_TOKEN=changeme
