ENVIRONMENT=development

POSTGRES_USER=argus
POSTGRES_PASSWORD=argus
POSTGRES_DB=argus
DATABASE_URL=postgresql+asyncpg://argus:argus@postgres:5432/argus

REDIS_URL=redis://redis:6379/0

QDRANT_URL=http://qdrant:6333

API_TOKEN=dev-token

# LLM (zero-cost mode): Gemini free tier primary, Groq free tier fallback.
# Get a free key at https://aistudio.google.com/apikey (Gemini)
# and/or https://console.groq.com/keys (Groq). At least one is required
# for /research/ask and the daily brief.
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GROQ_API_KEY=
# Optional paid fallback, off unless a key is set:
ANTHROPIC_API_KEY=

# Daily brief email (zero-cost: Gmail app password — https://myaccount.google.com/apppasswords).
# Without SMTP_USER/SMTP_PASSWORD/BRIEF_RECIPIENT the brief is still stored; the email is skipped.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
BRIEF_FROM=
BRIEF_RECIPIENT=
