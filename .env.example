ENVIRONMENT=development

POSTGRES_USER=argus
POSTGRES_PASSWORD=argus
POSTGRES_DB=argus
DATABASE_URL=postgresql+asyncpg://argus:argus@postgres:5432/argus

REDIS_URL=redis://redis:6379/0

QDRANT_URL=http://qdrant:6333

API_TOKEN=dev-token

# LLM (zero-cost mode): Gemini free tier primary, Groq free tier fallback.
# Get a free key at https://aistudio.google.com/apikey (Gemini)
# and/or https://console.groq.com/keys (Groq). At least one is required
# for /research/ask and the daily brief.
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GROQ_API_KEY=
# Optional paid fallback, off unless a key is set:
ANTHROPIC_API_KEY=
